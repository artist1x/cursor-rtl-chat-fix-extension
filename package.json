{
  "name": "cursor-rtl-chat-fix",
  "displayName": "Cursor RTL Chat Fix",
  "description": "Fixes Arabic/RTL/BiDi rendering in Cursor AI chat globally with backup and restore.",
  "version": "1.1.0",
  "publisher": "bsync-local",
  "license": "MIT",
  "icon": "media/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/artist1x/cursor-rtl-chat-fix-extension.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:cursorRtl.panel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "cursorRtl",
          "title": "Cursor RTL",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cursorRtl": [
        {
          "type": "webview",
          "id": "cursorRtl.panel",
          "name": "RTL Fix",
          "contextualTitle": "Cursor RTL Chat Fix"
        }
      ]
    },
    "commands": [
      {
        "command": "cursorRtl.openPanel",
        "title": "Open Cursor RTL Panel",
        "category": "Cursor RTL",
        "icon": {
          "light": "media/icon.svg",
          "dark": "media/icon.svg"
        }
      },
      {
        "command": "cursorRtl.applyFix",
        "title": "Cursor RTL: Apply Fix",
        "category": "Cursor RTL",
        "icon": {
          "light": "media/icon.svg",
          "dark": "media/icon.svg"
        }
      },
      {
        "command": "cursorRtl.checkStatus",
        "title": "Cursor RTL: Check Status",
        "category": "Cursor RTL"
      },
      {
        "command": "cursorRtl.restore",
        "title": "Cursor RTL: Restore Original Cursor Files",
        "category": "Cursor RTL"
      },
      {
        "command": "cursorRtl.reapply",
        "title": "Cursor RTL: Reapply After Cursor Update",
        "category": "Cursor RTL"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "cursorRtl.openPanel"
        },
        {
          "command": "cursorRtl.applyFix"
        },
        {
          "command": "cursorRtl.checkStatus"
        },
        {
          "command": "cursorRtl.restore"
        },
        {
          "command": "cursorRtl.reapply"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.3.3"
  }
}
